{
  "openapi": "3.1.0",
  "info": {
    "version": "1.0.0",
    "title": "Every.org Charity API"
  },
  "paths": {
    "/": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Charity Lookup widget",
        "description": "HTML widget resource for rendering charity search results.",
        "operationId": "charity-widget",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://project-ox76b.vercel.app"
            }
          },
          "policies": {
            "inbound": []
          },
          "mcp": {
            "type": "resource",
            "name": "charity_widget",
            "description": "HTML widget for charity search results.",
            "uri": "ui://widget/charity.html",
            "mimeType": "text/html+skybridge"
          }
        }
      }
    },
    "/v0.2/search/{searchTerm}": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "get": {
        "summary": "Search nonprofits",
        "description": "Search nonprofits by name.",
        "operationId": "search-nonprofits",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "urlForwardHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "baseUrl": "https://partners.every.org"
            }
          },
          "policies": {
            "inbound": [
              "inject-every-org-api-key"
            ]
          },
          "mcp": {
            "type": "tool",
            "name": "search_nonprofits",
            "description": "Search nonprofits and render results in the Charity Lookup widget.",
            "_meta": {
              "ui": {
                "resourceUri": "ui://widget/charity.html"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "searchTerm",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/mcp": {
      "x-zuplo-path": {
        "pathMode": "open-api"
      },
      "post": {
        "summary": "MCP Server",
        "description": "Default MCP Server",
        "operationId": "charity-mcp-server",
        "x-zuplo-route": {
          "corsPolicy": "none",
          "handler": {
            "export": "mcpServerHandler",
            "module": "$import(@zuplo/runtime)",
            "options": {
              "name": "Charity Lookup MCP Server",
              "version": "1.0.0",
              "operations": [
                {
                  "file": "./config/routes.oas.json",
                  "id": "search-nonprofits"
                },
                {
                  "file": "./config/routes.oas.json",
                  "id": "charity-widget"
                }
              ]
            }
          },
          "policies": {
            "inbound": []
          }
        }
      }
    }
  }
}